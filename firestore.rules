rules_version = '2';

// ВАЖНО: при изменении этого файла прогоняй `npm run test:integration`.
// Регрессионная матрица: tests/integration/firestoreRules.test.ts — проверяет
// list/get/write по всем критичным коллекциям. Не уверен в правке catch-all
// или в новой коллекции — гарантированно красные тесты до деплоя.

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == 'biboandbobo2@gmail.com';
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() &&
        request.auth.token.role != null &&
        request.auth.token.role in ['admin', 'super-admin']
      );
    }

    // Со-админ страниц DOM Academy. Параллельный флаг — не зависит от
    // userRole. Источник истины: custom claim `coAdmin: true`.
    // super-admin всегда считается co-admin (включает все co-admin-фичи).
    function isCoAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() &&
        request.auth.token.coAdmin == true
      );
    }

    function canEditCourse(courseId) {
      return isSuperAdmin() || (
        isAuthenticated() &&
        request.auth.token.role == 'admin' &&
        request.auth.token.editableCourses is list &&
        courseId in request.auth.token.editableCourses
      );
    }

    function isValidStudentStream(stream) {
      return stream in ['first', 'second', 'none'];
    }

    function isAdminStudentStreamUpdate() {
      return isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['studentStream', 'studentStreamUpdatedAt', 'studentStreamUpdatedBy']) &&
        !(resource.data.get('role', '') in ['admin', 'super-admin']) &&
        isValidStudentStream(request.resource.data.studentStream) &&
        request.resource.data.studentStreamUpdatedBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isSuperAdmin() || isAdminStudentStreamUpdate();
      allow delete: if isSuperAdmin();

      // Прогресс просмотра курсов (resume point, last-lesson, watched).
      // Один документ на курс. Multi-device: clients пишут гибридно
      // (localStorage + cloud throttle); читают cloud-first.
      match /courseProgress/{courseId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Группы студентов (потоки). Создание/редактирование — супер-админ.
    // Чтение — любые админы (для управления), участники группы и админы,
    // назначенные писать объявления этой группе (announcementAdminIds).
    match /groups/{groupId} {
      function canReadGroup() {
        return isAuthenticated() && (
          isAdmin() ||
          (request.auth.uid in resource.data.memberIds) ||
          (request.auth.uid in resource.data.announcementAdminIds)
        );
      }
      function canWriteGroupFeed() {
        return isSuperAdmin() || (
          isAuthenticated() &&
          request.auth.token.role == 'admin' &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.announcementAdminIds
        );
      }
      function isGroupMemberOrAdmin() {
        return isAuthenticated() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.announcementAdminIds
        );
      }

      allow read: if canReadGroup();
      allow create, update, delete: if isSuperAdmin();

      // Объявления группы «Все» читаются публично (anonymous) — это
      // новости платформы, которые видят все гости /home. Для любой
      // другой группы чтение ограничено участниками/админами.
      match /announcements/{annId} {
        allow read: if groupId == 'everyone' || isGroupMemberOrAdmin();
        allow create, update, delete: if canWriteGroupFeed();
      }

      match /events/{eventId} {
        allow read: if isGroupMemberOrAdmin();
        allow create, update, delete: if canWriteGroupFeed();
      }
    }

    // Вопросы студентов по занятиям курса (из режима конспекта или со
    // страницы занятия). Читают: автор, лекторы курса (canEditCourse) и —
    // при visibility='group' — участники группы автора. Запросы клиента
    // используют только equality-фильтры (composite-индексы не нужны).
    match /lectureQuestions/{questionId} {
      function isQuestionAuthor() {
        return isAuthenticated() && resource.data.authorUid == request.auth.uid;
      }
      function isQuestionGroupMember() {
        return isAuthenticated() &&
          resource.data.visibility == 'group' &&
          resource.data.groupId is string &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds;
      }

      allow get, list: if isQuestionAuthor()
        || canEditCourse(resource.data.courseId)
        || isQuestionGroupMember();

      allow create: if isAuthenticated()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.courseId is string
        && request.resource.data.periodId is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        && request.resource.data.visibility in ['group', 'lecturers']
        && (
          request.resource.data.visibility == 'lecturers' ||
          (
            request.resource.data.groupId is string &&
            request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberIds
          )
        );

      // Вопрос — снапшот к семинару: правок нет, только удаление
      // автором или лектором курса.
      allow update: if false;
      allow delete: if isQuestionAuthor() || canEditCourse(resource.data.courseId);
    }

    // Legacy коллекции курса "Психология развития" (возрастные периоды + intro)
    match /intro/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /prenatal/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /early-childhood/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /preschool/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /primary-school/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /adolescence/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /periods/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    // Legacy: клинические темы курса "Клиническая психология"
    match /clinical-topics/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('clinical');
    }
    // Темы общей психологии
    match /general-topics/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('general');
    }
    // Dynamic-курсы: документ курса и его занятия
    match /courses/{courseId} {
      allow read: if true;
      allow write: if canEditCourse(courseId);
      match /lessons/{document=**} {
        allow read: if true;
        allow write: if canEditCourse(courseId);
      }
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /topics/{topicId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /testResults/{resultId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /timelines/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Таблица по расстройствам (личные записи студента)
    match /disorderTables/{docId} {
      function isDisorderTableOwner() {
        return isAuthenticated() && docId.matches('^' + request.auth.uid + '_[A-Za-z0-9-]+$');
      }

      allow read: if isDisorderTableOwner() || isAdmin();
      allow create, update, delete: if isDisorderTableOwner();

      match /entries/{entryId} {
        allow read: if isDisorderTableOwner() || isAdmin();
        allow create, update, delete: if isDisorderTableOwner();
      }

      match /comments/{commentId} {
        allow read: if isDisorderTableOwner() || isAdmin();
        allow create, update, delete: if isAdmin();
      }
    }

    // HomePage content and other public pages
    match /pages/{pageId} {
      allow read: if true; // Public read access for homepage
      allow write: if isAdmin() || isCoAdmin(); // admins + DOM Academy co-admins
    }

    // Страницы проектов академии (/projects/:slug).
    // Read public, write super-admin или co-admin.
    match /projectPages/{slug} {
      allow read: if true;
      allow write: if isCoAdmin();
    }

    // BYOK usage счётчик (волна 6). Документ ID = `${uid}_${day}`, где день в UTC.
    // Read — только сам пользователь. Write — только server-side (admin SDK обходит rules).
    match /aiUsageDaily/{docId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Biography pipeline jobs (server writes via Admin SDK, user reads own).
    match /biographyJobs/{jobId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // История поисков пользователя
    match /searchHistory/{entryId} {
      allow read, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
    }

    // Экзамены и бронирование слотов. Запись (создание слотов и брони) —
    // только server-side (super-admin вручную через консоль или Cloud
    // Function под Admin SDK). Клиентам разрешён только read согласно
    // приватности: публичный факт занятости — всем, имена и эссе — только
    // владельцу и super-admin.
    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();

      // Слот: время начала/конца + map bookings (только {bookedAt} как факт занятости).
      match /slots/{slotId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isSuperAdmin();
      }

      // Детали брони (имя, email, slotId, groupId). Document ID = `${slotId}__${groupId}`.
      // Read: только владелец брони или super-admin. Соседу по слоту имена не видны.
      match /bookingDetails/{detailsId} {
        allow read: if isSuperAdmin() ||
          (isAuthenticated() && resource.data.userId == request.auth.uid);
        allow create, update, delete: if isSuperAdmin();
      }

      // Эссе. Read: владелец или super-admin. Write — только server-side.
      match /essays/{userId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow create, update, delete: if isSuperAdmin();
      }

      // Индекс «у юзера есть бронь» (для O(1) проверки уникальности). Read: владелец или super-admin.
      match /userIndex/{userId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow create, update, delete: if isSuperAdmin();
      }
    }

    // Тесты курса (динамические тесты в /tests и /tests-lesson).
    // Чтение публичное — раньше работало через catch-all с `allow read: if true`.
    // Запись — только админ (создание/редактирование в /admin/content).
    match /tests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Админская служебная коллекция (например, admin/task-board — метрики
    // производительности в /superadmin). Доступ только админам.
    match /admin/{docId} {
      allow read, write: if isAdmin();
    }

    // Лента «Новости платформы и события» на /home (документ homeFeed/shared).
    // Хук useHomeFeed сейчас нигде не вызывается, но коллекция поддерживается
    // на случай реактивации: чтение публичное (как pages), запись — админ.
    match /homeFeed/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Server-only RAG / транскрипты / job-коллекции.
    // Клиенты к ним не ходят — доступ только через Admin SDK
    // (Cloud Functions, api/* с server-side ключом), который обходит rules.
    //
    // Исключение: метаданные videoTranscripts открыты на чтение, потому что
    // сами payload-файлы публичны в Storage (`video-transcripts/**`) и
    // клиентский useVideoTranscript читает их напрямую. Write остаётся
    // server-only.
    match /videoTranscripts/{videoId} {
      allow read: if true;
      allow write: if false;
    }
    match /videoTranscriptSearch/{videoId} {
      allow read, write: if false;
      match /searchChunks/{chunkId} {
        allow read, write: if false;
      }
    }
    match /transcriptJobs/{jobName} {
      allow read, write: if false;
      match /runs/{runId} {
        allow read, write: if false;
      }
    }
    match /lecture_sources/{lectureKey} {
      allow read, write: if false;
    }
    match /lecture_chunks/{chunkId} {
      allow read, write: if false;
    }
    match /lecture_ingestion_jobs/{jobId} {
      allow read, write: if false;
    }
    match /books/{bookId} {
      allow read, write: if false;
    }
    match /book_chunks/{chunkId} {
      allow read, write: if false;
    }
    match /ingestion_jobs/{jobId} {
      allow read, write: if false;
    }
    match /studentEmailLists/{docId} {
      allow read, write: if false;
    }
    match /opsRuntime/{docId} {
      allow read, write: if false;
    }

    // Default-deny для всех остальных коллекций. Любая новая коллекция
    // должна получить свой явный `match`-блок выше — иначе read/write
    // запрещены. Это закрытие MR-8: больше нет catch-all `allow read: if true`,
    // который пропускал чтение любого приватного документа.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
