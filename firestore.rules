rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == 'biboandbobo2@gmail.com';
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() &&
        request.auth.token.role != null &&
        request.auth.token.role in ['admin', 'super-admin']
      );
    }

    function canEditCourse(courseId) {
      return isSuperAdmin() || (
        isAuthenticated() &&
        request.auth.token.role == 'admin' &&
        request.auth.token.editableCourses is list &&
        courseId in request.auth.token.editableCourses
      );
    }

    function isValidStudentStream(stream) {
      return stream in ['first', 'second', 'none'];
    }

    function isAdminStudentStreamUpdate() {
      return isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['studentStream', 'studentStreamUpdatedAt', 'studentStreamUpdatedBy']) &&
        !(resource.data.get('role', '') in ['admin', 'super-admin']) &&
        isValidStudentStream(request.resource.data.studentStream) &&
        request.resource.data.studentStreamUpdatedBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isSuperAdmin() || isAdminStudentStreamUpdate();
      allow delete: if isSuperAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Группы студентов (потоки). Создание/редактирование — супер-админ.
    // Чтение — любые админы (для управления), участники группы и админы,
    // назначенные писать объявления этой группе (announcementAdminIds).
    match /groups/{groupId} {
      function canReadGroup() {
        return isAuthenticated() && (
          isAdmin() ||
          (request.auth.uid in resource.data.memberIds) ||
          (request.auth.uid in resource.data.announcementAdminIds)
        );
      }
      function canWriteGroupFeed() {
        return isSuperAdmin() || (
          isAuthenticated() &&
          request.auth.token.role == 'admin' &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.announcementAdminIds
        );
      }
      function isGroupMemberOrAdmin() {
        return isAuthenticated() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.announcementAdminIds
        );
      }

      allow read: if canReadGroup();
      allow create, update, delete: if isSuperAdmin();

      // Объявления группы «Все» читаются публично (anonymous) — это
      // новости платформы, которые видят все гости /home. Для любой
      // другой группы чтение ограничено участниками/админами.
      match /announcements/{annId} {
        allow read: if groupId == 'everyone' || isGroupMemberOrAdmin();
        allow create, update, delete: if canWriteGroupFeed();
      }

      match /events/{eventId} {
        allow read: if isGroupMemberOrAdmin();
        allow create, update, delete: if canWriteGroupFeed();
      }
    }

    // Legacy коллекции курса "Психология развития" (возрастные периоды + intro)
    match /intro/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /prenatal/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /early-childhood/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /preschool/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /primary-school/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /adolescence/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    match /periods/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('development');
    }
    // Legacy: клинические темы курса "Клиническая психология"
    match /clinical-topics/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('clinical');
    }
    // Темы общей психологии
    match /general-topics/{document=**} {
      allow read: if true;
      allow write: if canEditCourse('general');
    }
    // Dynamic-курсы: документ курса и его занятия
    match /courses/{courseId} {
      allow read: if true;
      allow write: if canEditCourse(courseId);
      match /lessons/{document=**} {
        allow read: if true;
        allow write: if canEditCourse(courseId);
      }
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /topics/{topicId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /testResults/{resultId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /timelines/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Таблица по расстройствам (личные записи студента)
    match /disorderTables/{docId} {
      function isDisorderTableOwner() {
        return isAuthenticated() && docId.matches('^' + request.auth.uid + '_[A-Za-z0-9-]+$');
      }

      allow read: if isDisorderTableOwner() || isAdmin();
      allow create, update, delete: if isDisorderTableOwner();

      match /entries/{entryId} {
        allow read: if isDisorderTableOwner() || isAdmin();
        allow create, update, delete: if isDisorderTableOwner();
      }

      match /comments/{commentId} {
        allow read: if isDisorderTableOwner() || isAdmin();
        allow create, update, delete: if isAdmin();
      }
    }

    // HomePage content and other public pages
    match /pages/{pageId} {
      allow read: if true; // Public read access for homepage
      allow write: if isAdmin(); // Only admins can edit
    }

    // Страницы проектов академии (/projects/:slug). Read public, write super-admin.
    match /projectPages/{slug} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // История поисков пользователя
    match /searchHistory/{entryId} {
      allow read, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
